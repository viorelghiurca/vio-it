# Firebase – Eigene Werte aus Firebase Console eintragen
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# EmailJS – https://www.emailjs.com
# Service ID (z.B. service_xxxxxxx)
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
# Template: Kunden-Buchungsbestätigung (email-templates/template-kunde-bestaetigung.html)
VITE_EMAILJS_TEMPLATE_BESTAETIGUNG=template_xxxxxxx
# Template: Kunden-Stornierungsbestätigung (email-templates/template-kunde-stornierung.html)
VITE_EMAILJS_TEMPLATE_STORNIERUNG=template_xxxxxxx
# Template: Admin-Benachrichtigung (email-templates/template-admin.html)
VITE_EMAILJS_TEMPLATE_ADMIN=template_xxxxxxx
# Public Key (Account → API Keys)
VITE_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY
# Basis-URL der Website (für Stornierungs-Links)
VITE_BASE_URL=https://it.ghiurcaviorel.de
